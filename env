#--------------------------------------------------------------------
# Configuracion de entorno para deploy (CodeIgniter 4)
#
# Este archivo sirve como base para el .env del servidor.
# Ajusta los valores segun tu hosting antes de publicar.
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# PRODUCCION (ACTIVO EN DEPLOY)
#--------------------------------------------------------------------

CI_ENVIRONMENT = production
app.baseURL = 'https://alcaldia.com.ar/'
app.forceGlobalSecureRequests = true

# Ruta absoluta privada para instaladores (fuera de public_html).
# Si no se define, la app usa ROOTPATH/distribucion.
downloads.path = '/home/a0010463/distribucion'

# Clave usada para firmar tokens HMAC de descarga.
# Debe ser larga, aleatoria y secreta.
encryption.key = 'REEMPLAZAR_POR_CLAVE_LARGA_Y_ALEATORIA'

#--------------------------------------------------------------------
# LOGS
#--------------------------------------------------------------------

# En produccion se recomienda nivel 3 (errores).
logger.threshold = 3

