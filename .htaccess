# Bloquea acceso directo a carpetas sensibles
RedirectMatch 403 ^/(app|vendor|writable|storage|system)(/?.*)?$

# Redirige todo al entry point de CI4 en public/
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Evita reescrituras duplicadas cuando la request ya apunta a public/.
    RewriteRule ^public/ - [L]

    # Fuerza que toda la navegacion publica pase por el front controller de CI4.
    RewriteRule ^$ public/ [L]
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
