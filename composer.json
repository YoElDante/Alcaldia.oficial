{
    "name": "alcaldia/web-oficial",
    "description": "Portal web oficial ALCALDIA - Software de gestión municipal",
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^8.1",
        "codeigniter4/framework": "^4.6"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "scripts": {
        "dev": "php spark serve --host 127.0.0.1 --port 8080",
        "start": "php -S 127.0.0.1:8080 -t public public/router.php"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable"
}